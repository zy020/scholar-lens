# ===== Shared Credentials =====
# All models inherit these unless overridden individually
API_KEY=replace-with-your-api-key
BASE_URL=https://api.openai.com/v1

# ===== Model Names (required) =====
LLM__MODEL=gpt-4o-mini
EMBEDDING__MODEL=text-embedding-3-small

# ===== Optional Models =====
# Uncomment to enable:
# RERANKER__MODEL=bge-reranker-m3
# VISION__MODEL=gpt-4o

# ===== Per-Model Overrides (optional) =====
# Only needed if a specific model uses a different provider:
# LLM__API_KEY=replace-with-provider-specific-key
# LLM__BASE_URL=https://other-provider.com/v1
# RERANKER__API_KEY=replace-with-reranker-key
# RERANKER__BASE_URL=https://rerank-provider.com/v1

# ===== Evaluation Judge Model (optional) =====
# If omitted, evaluation uses the normal LLM config as judge.
# When the judge uses the same API key/base URL as the answer model, only set the model:
# EVAL_JUDGE__MODEL=Pro/moonshotai/Kimi-K2.6
# Optional per-judge overrides:
# EVAL_JUDGE__API_KEY=replace-with-judge-key
# EVAL_JUDGE__BASE_URL=https://judge-provider.com/v1
# EVAL_JUDGE__REQUEST_TIMEOUT=240
